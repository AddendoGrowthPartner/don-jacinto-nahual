    icon: '🌿',
    title: 'Enfermedades que no Ceden',
    desc: 'Acompañamiento espiritual para malestares prolongados sin diagnóstico claro y condiciones que los tratamientos convencionales no mejoran.',
  },
  {
    icon: '💼',
    title: 'Caminos Cerrados',
    desc: 'Trabajos espirituales para negocios que no prosperan, oportunidades que se pierden y problemas económicos sin explicación lógica.',
  },
  {
    icon: '🛡️',
    title: 'Brujería y Envidia',
    desc: 'Limpias, protección y defensa espiritual para víctimas de envidia, daños espirituales o energías puestas desde afuera.',
  },
];
---

<Layout
  title={title}
  description={description}
  businessName={businessName}
  businessDescription={businessDescription}
  preloadHero="/images/don-jacinto-rezo.jpg"
>
  <!-- ============ HERO ============ -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
    <img
      src="/images/don-jacinto-rezo.jpg"
      alt={`Don Jacinto Nahual brujo curandero de Catemaco Veracruz guía espiritual en ${ciudad} California`}
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0;"
    />
    <div class="absolute inset-0 bg-black/75" style="z-index:1;"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-bg/40 via-transparent to-bg" style="z-index:1;"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 py-24 text-center">
      <div class="inline-block mb-6 px-5 py-2 border border-gold/40 rounded-full">
        <span class="text-gold-light text-xs sm:text-sm tracking-[0.2em] uppercase">
          ✦ Catemaco, Veracruz · {ciudad}, California ✦
        </span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold mb-3 text-text leading-tight">
        Brujo Curandero en {ciudad}
      </h1>
      <h2 class="font-display italic text-2xl sm:text-3xl md:text-4xl text-gold mb-8">
        Don Jacinto Nahual
      </h2>

      <p class="text-base sm:text-lg text-text/85 max-w-3xl mx-auto leading-relaxed mb-10">
        {intro}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
        <a
          href={phoneHref}
          class="bg-gold hover:bg-gold-light text-bg font-semibold px-8 py-4 rounded-full transition-all hover:scale-105 shadow-lg shadow-gold/20"
        >
          📞 Llamar: {phone}
        </a>
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="border-2 border-gold text-gold hover:bg-gold hover:text-bg font-semibold px-8 py-4 rounded-full transition-all hover:scale-105"
        >
          💬 WhatsApp
        </a>
      </div>

      <p class="text-xs sm:text-sm text-muted tracking-widest">
        ✦ Consultas presenciales · Tradición de Catemaco · Más de 30 años ✦
      </p>
    </div>
  </section>

  <!-- ============ INTRO CIUDAD ============ -->
  <section class="bg-bg-alt py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-gold text-xs tracking-[0.25em] uppercase mb-4">
            ✦ Presencia en {ciudad} ✦
          </p>
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl mb-6 leading-tight">
            Curandero Mexicano en {ciudad}
          </h2>
          <div class="space-y-4 text-text/85 text-base sm:text-lg leading-relaxed">
            <p>{intro}</p>
            <p>{intro2}</p>
          </div>
          <div class="mt-10">
            <a
              href={phoneHref}
              class="inline-block bg-gold hover:bg-gold-light text-bg font-semibold px-8 py-4 rounded-full transition-all"
            >
              Cuéntale tu caso a Don Jacinto →
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 border border-gold/30 rounded-lg"></div>
          <img
            src="/images/don-jacinto-curandero.jpg"
            alt={`Don Jacinto Nahual brujo curandero de Catemaco atendiendo consultas espirituales en ${ciudad} California`}
            class="relative w-full h-auto rounded-lg shadow-2xl"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 4 ÁREAS (condensado) ============ -->
  <section class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-gold text-xs tracking-[0.25em] uppercase mb-4">✦ Práctica espiritual ✦</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl mb-4">Áreas de Trabajo</h2>
        <p class="text-muted max-w-2xl mx-auto">
          Don Jacinto trabaja con cuatro áreas principales desde la tradición curanderil de
          Catemaco.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {areasCondensed.map((a) => (
          <div class="bg-bg-alt p-8 rounded-lg border border-gold/10 hover:border-gold/30 transition-colors">
            <div class="text-4xl mb-4">{a.icon}</div>
            <h3 class="font-display text-xl text-gold-light mb-3">{a.title}</h3>
            <p class="text-muted text-sm leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="relative py-24 sm:py-28 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/images/altar-espiritual.jpg');"
    >
    </div>
    <div class="absolute inset-0 bg-bg/90"></div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <p class="text-gold text-xs tracking-[0.25em] uppercase mb-4">✦ Contacto ✦</p>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl mb-6 text-text leading-tight">
        ¿Buscas un brujo curandero en {ciudad}?
      </h2>
      <p class="text-text/85 text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
        Don Jacinto Nahual atiende personalmente a la comunidad latina de {ciudad} y todo el sur
        de California. Décadas de práctica espiritual en la tradición ancestral de Catemaco,
        Veracruz. La primera llamada no tiene costo.
      </p>

      <div class="bg-bg-alt/80 backdrop-blur border border-gold/20 rounded-lg p-8 mb-10">
        <div class="text-gold-light font-display text-xl mb-2">📍 1208 Venice Blvd</div>
        <div class="text-text/85 mb-6">Los Angeles, CA 90006</div>
        <div class="text-gold font-display text-3xl">{phone}</div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
        <a
          href={phoneHref}
          class="bg-gold hover:bg-gold-light text-bg font-semibold px-8 py-4 rounded-full transition-all"
        >
          📞 Llamar Ahora
        </a>
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="border-2 border-gold text-gold hover:bg-gold hover:text-bg font-semibold px-8 py-4 rounded-full transition-all"
        >
          💬 WhatsApp
        </a>
      </div>

      <p class="text-muted text-sm tracking-wide">
        Atención confidencial · Tradición de Catemaco, Veracruz
      </p>
    </div>
  </section>

  <!-- ============ BACK LINK ============ -->
  <section class="bg-bg-alt py-12 border-t border-gold/10">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <a
        href="/"
        class="inline-block text-gold hover:text-gold-light text-sm tracking-wider uppercase transition-colors"
      >
        ← Ver todos los servicios
      </a>
    </div>
  </section>

  <!-- ============ WHATSAPP FLOTANTE ============ -->
  <a
    href={wa}
    target="_blank"
    rel="noopener"
    aria-label="Contactar por WhatsApp"
    class="fixed bottom-6 right-6 z-50 bg-gold hover:bg-gold-light text-bg font-semibold px-5 py-3 rounded-full shadow-2xl shadow-gold/30 flex items-center gap-2 transition-all hover:scale-105"
  >
    <span class="text-xl">💬</span>
    <span class="hidden sm:inline text-sm">WhatsApp</span>
  </a>
</Layout>
