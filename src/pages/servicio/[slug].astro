---
import Layout from '../../layouts/Layout.astro';
import WhatsAppLink from '../../components/WhatsAppLink.astro';

const phone = '(213) 598-1928';
const phoneHref = 'tel:+12135981928';

const waMessagesBySlug: Record<string, string> = {
  'ayuda-espiritual-amor': 'Hola, necesito ayuda con un problema de amor 🙏',
  'curaciones-espirituales': 'Hola, tengo un malestar que no mejora y necesito ayuda 🙏',
  'mal-de-ojo': 'Hola, creo que me hicieron mal de ojo y necesito ayuda 🙏',
};

export async function getStaticPaths() {
  const servicios = [
    {
      slug: 'ayuda-espiritual-amor',
      title: 'Ayuda Espiritual para el Amor en Los Ángeles | Don Jacinto Nahual',
      description:
        'Don Jacinto Nahual ofrece ayuda espiritual para recuperar el amor, sanar relaciones y resolver separaciones en Los Ángeles California. Llama: (213) 598-1928',
      heroImg: '/images/amor-pareja.webp',
      heroAlt:
        'Ayuda espiritual para el amor y la pareja Don Jacinto Nahual curandero Catemaco',
      h1: 'Ayuda Espiritual para el Amor',
      h2Subtitle: 'Cuando el amor se pierde sin razón',
      intro: [
        'Hay separaciones que no tienen explicación lógica. Una pareja estable que de repente se enfría. Un amor que desaparece de la noche a la mañana. Una relación destruida por interferencias externas que no puedes ver. En la tradición curanderil, estas situaciones tienen nombre — y tienen solución.',
        'Don Jacinto Nahual trabaja los casos de amor desde la raíz espiritual del problema. No con promesas de resultados garantizados — porque cada caso es único — sino con la honestidad y la experiencia de más de 30 años acompañando a personas que creyeron que su amor estaba perdido para siempre.',
        'Perder a la persona que amas es uno de los dolores más profundos que existen. La separación, la frialdad repentina, el distanciamiento sin razón aparente o la presencia de una tercera persona destruyen lo que costó años construir. Muchas personas en Los Ángeles y California llegan con Don Jacinto después de haber intentado todo — conversaciones, terapia, tiempo — sin resultado. A través de la orientación espiritual y los trabajos de amor de la tradición de Catemaco, Don Jacinto trabaja para restablecer el vínculo, eliminar interferencias espirituales y abrir el camino hacia la reconciliación. Si sientes que tu relación tiene una influencia externa o que el amor se apagó de golpe, hay una respuesta espiritual.',
      ],
      listSection: {
        h2: 'Situaciones en las que Don Jacinto puede ayudarte',
        items: [
          'Tu pareja se alejó sin darte una razón clara',
          'Hay un tercero interfiriendo en tu relación',
          'Sientes que le pusieron un amarre a tu pareja',
          'Tu matrimonio se está destruyendo a pesar de todo',
          'Llevas tiempo solo y el amor no llega',
          'Una relación pasada que no puedes superar',
        ],
      },
      paragraphSection: {
        h2: 'Lo que Don Jacinto no te va a prometer',
        text: 'Don Jacinto Nahual no garantiza resultados específicos en ningún caso de amor. Cualquier curandero que te garantice recuperar a una persona específica te está mintiendo. Lo que sí puede hacer: evaluar tu caso con honestidad, trabajar espiritualmente lo que esté a su alcance y acompañarte en el proceso.',
      },
      ctaText:
        'Si tu corazón está sufriendo y sientes que ya intentaste todo, cuéntale tu caso a Don Jacinto. Él te escucha sin juicios y te dice con honestidad qué puede hacer.',
    },
    {
      slug: 'curaciones-espirituales',
      title: 'Curaciones Espirituales en Los Ángeles | Don Jacinto Nahual',
      description:
        'Don Jacinto Nahual realiza curaciones espirituales para enfermedades sin diagnóstico en Los Ángeles California. Tradición curanderil de Catemaco. Llama: (213) 598-1928',
      heroImg: '/images/don-jacinto-ritual.webp',
      heroAlt:
        'Curación espiritual enfermedades inexplicables Don Jacinto Nahual chamán Catemaco',
      h1: 'Curaciones Espirituales',
      h2Subtitle: 'Cuando la medicina no tiene respuesta',
      intro: [
        'Hay enfermedades que los médicos no encuentran. Malestares que llevan meses o años sin diagnóstico. Dolores que van y vienen sin causa. Fatiga profunda que no responde a ningún tratamiento. En la tradición curanderil mexicana, estas condiciones a veces tienen raíz espiritual — y un trabajo espiritual puede acompañar el proceso.',
        'Don Jacinto Nahual no reemplaza a los médicos. Su trabajo es complementario — actúa sobre lo que la medicina no puede ver. Si llevas tiempo buscando respuestas y no las encuentras, quizás es momento de explorar si hay algo espiritual detrás de lo que estás viviendo.',
        'Cuando los médicos ya no tienen respuesta, muchas personas de la comunidad latina en Los Ángeles y el sur de California buscan otro camino. Don Jacinto Nahual, curandero de Catemaco con más de 30 años de práctica espiritual, trabaja con rituales ancestrales, hierbas sagradas y oración para acompañarte espiritualmente cuando la medicina sola no alcanza. No promete cura ni reemplaza al médico — su rol es ofrecerte un acompañamiento honesto desde la tradición curanderil mexicana.',
      ],
      listSection: {
        h2: 'Condiciones que Don Jacinto ha acompañado',
        items: [
          'Malestares prolongados sin diagnóstico médico claro',
          'Dolores físicos que van y vienen sin causa identificable',
          'Fatiga extrema que no mejora con descanso ni tratamiento',
          'Condiciones que empeoran a pesar del tratamiento médico',
          'Enfermedades que aparecieron de repente tras un conflicto',
          'Malestares que varios médicos no han podido explicar',
        ],
      },
      paragraphSection: {
        h2: 'Importante — Lo que Don Jacinto no garantiza',
        text: 'Don Jacinto Nahual trabaja desde la tradición espiritual, no desde la medicina. No garantiza curas ni resultados específicos. Lo que sí ofrece es una evaluación honesta: si después de escucharte considera que puede ayudarte, te lo dice. Si considera que tu caso requiere atención médica específica, también te lo dice. Honestidad ante todo.',
      },
      ctaText:
        'Si llevas tiempo con algo que los médicos no han podido resolver, cuéntale tu caso a Don Jacinto.',
    },
    {
      slug: 'mal-de-ojo',
      title: 'Mal de Ojo: Limpia Tradicional en Los Ángeles',
      description:
        'Don Jacinto Nahual realiza limpias tradicionales del mal de ojo en Los Ángeles y el sur de California. Curandero de Catemaco con más de 30 años de práctica espiritual. Llama: (213) 598-1928',
      heroImg: '/images/don-jacinto-rezo.webp',
      heroAlt:
        'Limpia tradicional del mal de ojo Don Jacinto Nahual curandero de Catemaco Los Ángeles California',
      h1: 'Mal de Ojo',
      h2Subtitle: 'Cuando una mirada cargada deja huella',
      intro: [
        'En la tradición curanderil mexicana, el mal de ojo es una de las creencias más antiguas: la idea de que una mirada cargada de envidia, codicia o admiración intensa puede dejar una huella en quien la recibe. No es algo que la medicina contemple — es un concepto cultural que vive desde hace siglos en México y América Latina.',
        'Don Jacinto Nahual no diagnostica enfermedades ni promete cura. Su trabajo es realizar la limpia tradicional del mal de ojo dentro de la tradición curanderil de Catemaco, Veracruz — del mismo modo que se ha hecho durante generaciones. Si los malestares que sientes podrían tener una causa médica, lo más responsable es consultar primero con un profesional de la salud.',
        'Muchas personas de la comunidad latina en Los Ángeles y el sur de California conservan esta tradición y buscan a Don Jacinto cuando sienten que algo invisible los está afectando — cansancio sin causa, mala suerte que se repite, sensación de pesadez que no se explica. Don Jacinto, curandero de Catemaco con más de 30 años de práctica espiritual, realiza la limpia tradicional con hierbas, oración y elementos ancestrales — el mismo método que se usa en los pueblos del sureste mexicano. No promete resultados ni reemplaza atención profesional. Lo que ofrece es la tradición tal como se ha transmitido.',
      ],
      listSection: {
        h2: 'Señales que la tradición asocia al mal de ojo',
        items: [
          'Cansancio profundo sin razón aparente',
          'Sensación de pesadez que aparece de golpe',
          'Bostezos repetidos en momentos no esperados',
          'Mala suerte que se repite en lo cotidiano',
          'Malestar que aparece tras un encuentro o una mirada',
          'Inquietud o desánimo que no logras explicar',
        ],
      },
      paragraphSection: {
        h2: 'Cómo trabaja Don Jacinto',
        text: 'Don Jacinto realiza la limpia del mal de ojo con el método tradicional de Catemaco: hierbas frescas, oración, agua bendita y, según el caso, huevo. El proceso varía según cada persona — Don Jacinto evalúa primero y te dice con honestidad si considera que la limpia tradicional puede ayudarte o si tu caso requiere atención profesional. No promete cura ni resultados específicos.',
      },
      ctaText:
        'Si llevas tiempo sintiendo algo que no logras explicar, cuéntale tu caso a Don Jacinto.',
    },
  ];

  return servicios.map((s) => ({
    params: { slug: s.slug },
    props: s,
  }));
}

const s = Astro.props;
const waMessage = waMessagesBySlug[s.slug];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.h1,
  description: s.description,
  provider: {
    '@type': 'LocalBusiness',
    '@id': 'https://www.donjacintonahual.com/#business',
    name: 'Don Jacinto Nahual',
    telephone: '+1-213-598-1928',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '1208 Venice Blvd',
      addressLocality: 'Los Angeles',
      addressRegion: 'CA',
      postalCode: '90006',
      addressCountry: 'US',
    },
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Southern California',
  },
};
---

<Layout title={s.title} description={s.description} preloadHero={s.heroImg}>
  <!-- ============ HERO ============ -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <img
      src={s.heroImg}
      alt={s.heroAlt}
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;z-index:0;"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/30 to-bg" style="z-index:1;"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 py-24 text-center">
      <div class="inline-block mb-6 px-5 py-2 border border-gold/40 rounded-full">
        <span class="text-gold-light text-xs sm:text-sm tracking-[0.2em] uppercase">
          ✦ Tradición de Catemaco, Veracruz ✦
        </span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold mb-4 text-text leading-tight drop-shadow-[0_2px_10px_rgba(0,0,0,0.85)]">
        {s.h1}
      </h1>
      <h2 class="font-display italic text-2xl sm:text-3xl text-gold mb-8 drop-shadow-[0_2px_8px_rgba(0,0,0,0.85)]">
        {s.h2Subtitle}
      </h2>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={phoneHref}
          class="bg-gold hover:bg-gold-light text-bg font-semibold px-8 py-4 rounded-full transition-all hover:scale-105"
        >
          <svg aria-hidden="true" class="inline-block w-[0.95em] h-[0.95em] mr-1.5 align-[-0.08em]" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>Llamar: {phone}
        </a>
        <WhatsAppLink
          prefilledMessage={waMessage}
          style="display:inline-flex;align-items:center;gap:0.5rem;background:#0D5C2E;color:white;font-weight:600;font-size:0.875rem;padding:0.75rem 1.5rem;border-radius:9999px;text-decoration:none;"
        >
          <svg viewBox="0 0 24 24" fill="white" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </WhatsAppLink>
      </div>
    </div>
  </section>

  <!-- ============ BACK LINK ============ -->
  <section class="py-8 border-b border-gold/10">
    <div class="max-w-[720px] mx-auto px-6">
      <a
        href="/"
        class="text-gold hover:text-gold-light text-sm tracking-wider uppercase transition-colors"
      >
        ← Volver al inicio
      </a>
    </div>
  </section>

  <!-- ============ CONTENIDO ============ -->
  <article class="py-16 sm:py-20">
    <div class="max-w-[720px] mx-auto px-6">
      <div class="space-y-6 text-text/85 text-base sm:text-lg leading-relaxed mb-16">
        {s.intro.map((p) => <p>{p}</p>)}
      </div>

      <div class="mb-16">
        <h2 class="font-display text-2xl sm:text-3xl md:text-4xl text-gold-light mb-6 leading-tight">
          {s.listSection.h2}
        </h2>
        <ul class="space-y-3">
          {s.listSection.items.map((item) => (
            <li class="flex gap-3 text-text/85 leading-relaxed">
              <span class="text-gold flex-shrink-0 mt-1">✦</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mb-16">
        <h2 class="font-display text-2xl sm:text-3xl md:text-4xl text-gold-light mb-6 leading-tight">
          {s.paragraphSection.h2}
        </h2>
        <p class="text-text/85 text-base sm:text-lg leading-relaxed">
          {s.paragraphSection.text}
        </p>
      </div>
    </div>
  </article>

  <!-- ============ CTA ============ -->
  <section class="py-16 sm:py-20 bg-bg-alt border-t border-gold/10">
    <div class="max-w-[720px] mx-auto px-6">
      <div class="border border-gold/30 rounded-lg p-10 sm:p-14 bg-bg/60 text-center">
        <p class="text-gold text-xs tracking-[0.25em] uppercase mb-4">✦ Próximo paso ✦</p>
        <p class="text-text/90 text-lg sm:text-xl leading-relaxed mb-8">{s.ctaText}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={phoneHref}
            class="bg-gold hover:bg-gold-light text-bg font-semibold px-8 py-4 rounded-full transition-all"
          >
            <svg aria-hidden="true" class="inline-block w-[0.95em] h-[0.95em] mr-1.5 align-[-0.08em]" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>Llamar: {phone}
          </a>
          <WhatsAppLink
            prefilledMessage={waMessage}
            style="display:inline-flex;align-items:center;gap:0.5rem;background:#0D5C2E;color:white;font-weight:600;font-size:0.875rem;padding:0.75rem 1.5rem;border-radius:9999px;text-decoration:none;"
          >
            <svg viewBox="0 0 24 24" fill="white" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </WhatsAppLink>
        </div>
      </div>
    </div>
  </section>

  <!-- Service schema -->
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
</Layout>
