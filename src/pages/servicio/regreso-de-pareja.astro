    <p class="text-amber-50 text-sm sm:text-base leading-snug">Habla hoy con <strong class="text-white font-semibold">Don Jacinto</strong></p>
    <p class="font-display font-bold text-gold leading-none mt-1 drop-shadow-[0_2px_8px_rgba(0,0,0,0.75)]"><span class="text-4xl sm:text-5xl">LLAMA YA</span></p>
