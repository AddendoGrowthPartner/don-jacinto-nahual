          <div class="text-[0.62rem] sm:text-xs uppercase tracking-wider text-muted mt-1.5">Años de tradición</div>
        </div>
        <div>
          <div class="font-display text-2xl sm:text-3xl text-gold leading-none">+10.000</div>
          <div class="text-[0.62rem] sm:text-xs uppercase tracking-wider text-muted mt-1.5">Personas atendidas</div>
        </div>
