  </section>

  <!-- ============ SECCIÓN 5 — CTA MEDIO ============ -->
  <section class="relative py-20 sm:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-gold-dark via-gold/30 to-gold-dark"></div>
