      <script is:inline defer src="https://embed.cloudflarestream.com/embed/sdk.latest.js"></script>
      <script is:inline>
        (function () {
          function initPlay() {
            var btn = document.querySelector('.hero-video-play');
            if (!btn) return;
            var wrap = btn.closest('.hero-video-facade');
            if (!wrap) return;
            var originalHTML = wrap.innerHTML; // portada + botón (estado de diseño)
            btn.addEventListener('click', function () {
              var iframe = document.createElement('iframe');
              // Inyectar SIEMPRE como muted=true: garantiza que arranque a UN solo toque
              // (los navegadores bloquean el autoplay con sonido y mostrarían un 2º botón).
              // Luego intentamos activar el sonido vía SDK (funciona en escritorio/Android).
              iframe.src = btn.getAttribute('data-iframe-src').replace('muted=false', 'muted=true');
              iframe.title = 'Video de Don Jacinto';
              iframe.setAttribute('allow', 'autoplay; fullscreen; encrypted-media; picture-in-picture; accelerometer; gyroscope;');
              iframe.setAttribute('allowfullscreen', 'true');
              iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
              wrap.innerHTML = '';
              wrap.appendChild(iframe);
              // En MÓVIL (touch): NO forzar sonido — el video arranca en silencio a un solo
              // toque. Si intentáramos activar el sonido, iOS pausa el video y muestra otro botón.
              // Solo en ESCRITORIO (sin touch) activamos el sonido automáticamente.
              var isTouch = ('ontouchstart' in window) || (navigator.maxTouchPoints || 0) > 0;
              try {
                if (window.Stream) {
                  var player = window.Stream(iframe);
                  if (!isTouch) {
                    var unmute = function () {
                      try {
                        player.muted = false;
                        player.volume = 1;
                        var p = player.play();
                        if (p && p.catch) p.catch(function () {});
                      } catch (e) {}
                    };
                    unmute();
                    player.addEventListener('loadedmetadata', unmute);
                  }
                  // Al terminar: vuelve a la portada (evita la pantalla negra) y permite repetir
                  player.addEventListener('ended', function () {
                    wrap.innerHTML = originalHTML;
                    initPlay();
                  });
                }
              } catch (e) {}
            }, { once: true });
          }
          initPlay();
        })();
      </script>
    </>
