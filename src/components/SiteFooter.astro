---
import { servicios, blogsDestacados } from '../data/links.js';
import { ciudades } from '../data/ciudades.js';

const phone = '(213) 598-1928';
const phoneHref = 'tel:+12135981928';
// Ciudades ordenadas alfabéticamente para el footer.
const ciudadesOrden = [...ciudades].sort((a, b) => a.ciudad.localeCompare(b.ciudad, 'es'));
const year = 2026;
---

<footer class="bg-bg-alt border-t border-gold/15 pt-16 pb-10">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid gap-10 md:gap-8 md:grid-cols-12">
      <!-- Marca + contacto -->
      <div class="md:col-span-4">
        <a href="/" class="font-display text-2xl text-gold">Don Jacinto Nahual</a>
        <p class="text-muted text-sm leading-relaxed mt-4 max-w-xs">
          Brujo curandero de Catemaco, Veracruz. Más de 30 años de tradición espiritual al
          servicio de la comunidad latina en Los Ángeles y el sur de California.
        </p>
        <div class="mt-6 space-y-1 text-sm">
          <div class="text-gold-light font-display text-base">📍 1208 Venice Blvd</div>
          <div class="text-muted">Los Angeles, CA 90006</div>
          <a href={phoneHref} class="block text-gold font-display text-xl mt-2 hover:text-gold-light transition-colors">{phone}</a>
        </div>
      </div>

      <!-- Servicios -->
      <div class="md:col-span-3">
        <h3 class="text-gold text-xs tracking-[0.2em] uppercase mb-4">Servicios</h3>
        <ul class="space-y-2.5 text-sm">
          {servicios.map((s) => (
            <li>
              <a href={`/servicio/${s.slug}/`} class="text-text/75 hover:text-gold-light transition-colors">{s.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Blog + páginas -->
      <div class="md:col-span-5">
        <h3 class="text-gold text-xs tracking-[0.2em] uppercase mb-4">Del blog</h3>
        <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-2.5 text-sm">
          {blogsDestacados.map((b) => (
            <li>
              <a href={`/blog/${b.slug}/`} class="text-text/75 hover:text-gold-light transition-colors">{b.name}</a>
            </li>
          ))}
          <li><a href="/blog/" class="text-gold hover:text-gold-light transition-colors">Ver todo el blog →</a></li>
          <li><a href="/sobre-don-jacinto/" class="text-text/75 hover:text-gold-light transition-colors">Sobre Don Jacinto</a></li>
        </ul>
      </div>
    </div>

    <!-- Ciudades (enlazado local completo) -->
    <div class="mt-12 pt-10 border-t border-gold/10">
      <h3 class="text-gold text-xs tracking-[0.2em] uppercase mb-5">Brujo curandero por ciudad</h3>
      <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-6 gap-y-2.5 text-sm">
        {ciudadesOrden.map((c) => (
          <li>
            <a href={`/ciudad/${c.slug}/`} class="text-text/65 hover:text-gold-light transition-colors">{c.ciudad}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Legal -->
    <div class="mt-12 pt-8 border-t border-gold/10 flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between text-xs text-muted">
      <p>© {year} Don Jacinto Nahual · Tradición de Catemaco, Veracruz</p>
      <div class="flex gap-5">
        <a href="/" class="hover:text-gold-light transition-colors">Inicio</a>
        <a href="/aviso-legal/" class="hover:text-gold-light transition-colors">Aviso legal</a>
        <a href="/#contacto" class="hover:text-gold-light transition-colors">Contacto</a>
      </div>
    </div>
  </div>
</footer>
